Notebook[{

Cell[CellGroupData[{
Cell["EPS Axiomatics", "GuideTitle",ExpressionUUID->"9393d35f-c104-44af-b7a6-87374b77fd43"],

Cell["\<\
Ehlers-Pirani-Schild axiomatics on graphs: message and echo maps between \
worldlines built from outgoing light rays, with monotonicity (axiom D1) \
encoding the chronological order.\
\>", "GuideAbstract",ExpressionUUID->"c1c70a4c-53ea-4412-a7a5-9c4511bf0faa"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "GuideFunctionsSection",ExpressionUUID->"07f09b67-b91d-41d2-9d78-24e720deba29"],

Cell[CellGroupData[{

Cell["Message and echo functions", "GuideFunctionsSubsection",ExpressionUUID->"44166f18-e531-48f7-9bff-3936a4d6dc47"],

Cell[TextData[{
 Cell[BoxData["MultiMessageFunction"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "7e999bcf-6126-450a-92ee-24b6102052a3"],
 " \[LongDash] for each event on path1, the events on path2 reached by an \
outgoing light ray"
}], "GuideText",ExpressionUUID->"864191ec-51c8-4dfb-98b6-5b682e55cbbc"],

Cell[TextData[{
 Cell[BoxData["FindMessageFunction"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "b154133f-b3ae-4e7f-a2fd-3c00ce5059af"],
 " \[LongDash] all monotone single-valued selections, the EPS message maps"
}], "GuideText",ExpressionUUID->"1a773c69-0ddd-44ee-8353-bedb3b86ef9c"],

Cell[TextData[{
 Cell[BoxData["MultiEchoFunction"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "c8af6736-d5bd-4a00-8c61-74bee2a232c8"],
 " \[LongDash] set-valued round trip path1 to path2 and back"
}], "GuideText",ExpressionUUID->"758033b7-7a3f-4b41-a95f-ceca97486055"],

Cell[TextData[{
 Cell[BoxData["FindEchoFunction"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "6eb58e0d-33d9-4312-9e04-247c4e5c23be"],
 " \[LongDash] all monotone single-valued echo maps"
}], "GuideText",ExpressionUUID->"3a95a938-3a6d-4ea0-bbc9-f569203b66b7"],

Cell[TextData[{
 Cell[BoxData["EchoGraph"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "c97483f7-9ad3-4587-b854-fe35d394296c"],
 " \[LongDash] echo map as a directed graph from each event to its images"
}], "GuideText",ExpressionUUID->"2262afe5-37bd-4cba-b165-ab1f1dcdc493"],

Cell[TextData[{
 Cell[BoxData["MonotoneQ"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "db20b96a-566e-4edb-aa26-a7ed411192a2"],
 " \[LongDash] tests EPS axiom D1: the map preserves the chain order"
}], "GuideText",ExpressionUUID->"7ef552bf-4da0-4948-abba-24f9e68ea1a7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Visualization", "GuideFunctionsSubsection",ExpressionUUID->"62aab725-ec47-4a37-ab2d-fd94f26f1c6a"],

Cell[TextData[{
 Cell[BoxData["VisualizeMessageFunction"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "f5d9f996-8678-4fd9-b7c2-c6b4f3397773"],
 " \[LongDash] click an event on path1 to see its message images on path2"
}], "GuideText",ExpressionUUID->"1d3c546f-fb30-4b94-98d8-c6463aaddb53"],

Cell[TextData[{
 Cell[BoxData["VisualizeEchoFunction"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "70ea945f-b06f-4689-9ac0-d89c6803387d"],
 " \[LongDash] static overlay of the echo function"
}], "GuideText",ExpressionUUID->"fedb3a9b-6735-41e9-a882-08181e895b0c"]
}, Open  ]]
}, Open  ]],

