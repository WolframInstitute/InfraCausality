Notebook[{

Cell[CellGroupData[{
Cell["InfraCausality", "GuideTitle",ExpressionUUID->"9b273d07-51c7-4ef1-8b26-3b1d7e51677c"],

Cell["\<\
Causal structure and special relativity on finite metric spaces: events are \
vertices, causal order is reachability, observers are chains, and light rays \
are distinguished walks. Bondi k-calculus, the EPS axioms, and Knuth \
kinematics are rebuilt combinatorially.\
\>", "GuideAbstract",ExpressionUUID->"504d0cc7-cedc-4ae4-849e-1400cac56cba"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Related Guides", "GuideMoreAboutSection",ExpressionUUID->"52c693bb-7157-4cd6-893d-0788e6a88de4"],

Cell[TextData[{
 ButtonBox["CausalGraphs",
  BaseStyle->"Link",
  ButtonData->"paclet:WolframInstitute/InfraCausality/guide/CausalGraphs"],
 " \[LongDash] Causal graphs are finite directed acyclic graphs treated as \
causal sets: events are vertices, causal order is reachability, and observers \
are chains. This guide covers substrate generation, chain finding, the \
multi-realisation Infra wrappers, and the causal colour palette."
}], "GuideMoreAbout",ExpressionUUID->"2ace5925-9605-4982-a9aa-8021e24f36ac"],

Cell[TextData[{
 ButtonBox["LightConesAndUniversalTime",
  BaseStyle->"Link",
  ButtonData->
   "paclet:WolframInstitute/InfraCausality/guide/LightConesAndUniversalTime"],\

 " \[LongDash] Discrete light cones J+ and J-, causal intervals, the \
universal foliation by longest chain length from the sources, extremal events \
per slice, and combinatorial null geodesics."
}], "GuideMoreAbout",ExpressionUUID->"1cafc941-1a1c-4fa0-b96a-5dadcc5a8830"],

Cell[TextData[{
 ButtonBox["KnuthKinematics",
  BaseStyle->"Link",
  ButtonData->
   "paclet:WolframInstitute/InfraCausality/guide/KnuthKinematics"],
 " \[LongDash] Knuth-style combinatorial kinematics: two chain projections \
play the role of light-cone coordinates p and q, and energy, momentum, mass, \
interval, and velocity are their algebraic combinations."
}], "GuideMoreAbout",ExpressionUUID->"3c7139d8-6d71-4532-b3f9-12fbcf63bc06"],

Cell[TextData[{
 ButtonBox["EPSAxiomatics",
  BaseStyle->"Link",
  ButtonData->"paclet:WolframInstitute/InfraCausality/guide/EPSAxiomatics"],
 " \[LongDash] Ehlers-Pirani-Schild axiomatics on graphs: message and echo \
maps between worldlines built from outgoing light rays, with monotonicity \
(axiom D1) encoding the chronological order."
}], "GuideMoreAbout",ExpressionUUID->"75c1c2f4-2c08-4883-a568-de82144357dd"],

Cell[TextData[{
 ButtonBox["BondiKCalculus",
  BaseStyle->"Link",
  ButtonData->"paclet:WolframInstitute/InfraCausality/guide/BondiKCalculus"],
 " \[LongDash] Bondi k-calculus as Euclidean geometry: two straight \
worldlines from a common origin with light zigzagging at a fixed angle phi; \
the k-factor emerges as an arc-length ratio and proper time is logarithmic in \
arc-length."
}], "GuideMoreAbout",ExpressionUUID->"0c933380-abfe-43b2-bbdb-283d1f3c8a9a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Related Links", "GuideRelatedLinksSection",ExpressionUUID->"643f1dc4-4656-4d23-b905-15fb152761ae"],

