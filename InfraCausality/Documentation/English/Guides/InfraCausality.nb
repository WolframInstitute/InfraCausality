 BaseStyle->"Hyperlink",
 ButtonData->{
   URL["https://github.com/WolframInstitute/InfraCausality"], 
   None}]], "GuideRelatedLinks",ExpressionUUID->"207e6e6f-878c-4879-918f-\
7cb80b559f8e"]
}, Open  ]],

