Notebook[{

Cell[CellGroupData[{
Cell["Causal Graphs and Chains", "GuideTitle",ExpressionUUID->"46eafba8-b7c6-43ed-baad-fc9e5178220f"],

Cell["\<\
Causal graphs are finite directed acyclic graphs treated as causal sets: \
events are vertices, causal order is reachability, and observers are chains. \
This guide covers substrate generation, chain finding, the multi-realisation \
Infra wrappers, and the causal colour palette.\
\>", "GuideAbstract",ExpressionUUID->"34e87379-15e5-46c2-8802-c53929317c4d"]
}, Open  ]],

