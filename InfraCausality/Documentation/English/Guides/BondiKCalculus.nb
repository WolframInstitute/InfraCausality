  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "be04a526-ec0b-4068-b906-e78db508e570"],
 " \[LongDash] Bondi k-factor Sqrt[(1+v)/(1-v)]; angular form KFactor[v, \
phi]"
}], "GuideText",ExpressionUUID->"38f8ef98-f23e-49df-8603-b06cf734c9be"],

