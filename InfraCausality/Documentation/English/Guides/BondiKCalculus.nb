Notebook[{

Cell[CellGroupData[{
Cell["Bondi k-Calculus", "GuideTitle",ExpressionUUID->"571c8bcf-cefe-475f-8da1-c2b8b7e97158"],

Cell["\<\
Bondi k-calculus as Euclidean geometry: two straight worldlines from a common \
origin with light zigzagging at a fixed angle phi; the k-factor emerges as an \
arc-length ratio and proper time is logarithmic in arc-length.\
\>", "GuideAbstract",ExpressionUUID->"37c084d9-cb84-41af-8f43-7e8404e31c6f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "GuideFunctionsSection",ExpressionUUID->"6af95cd5-39d2-4e18-a365-221dcf00469f"],

