  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "7f517097-79c9-4c52-8c31-4cd415971670"],
 " \[LongDash] Log[k]"
}], "GuideText",ExpressionUUID->"03733c94-15f6-4708-84da-b4b9bb21b7e9"],

