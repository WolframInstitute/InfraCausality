Notebook[{

Cell[CellGroupData[{
Cell["Knuth Kinematics", "GuideTitle",ExpressionUUID->"1b2cfc2e-c42b-429e-bd18-a87c359d2f11"],

Cell["\<\
Knuth-style combinatorial kinematics: two chain projections play the role of \
light-cone coordinates p and q, and energy, momentum, mass, interval, and \
velocity are their algebraic combinations.\
\>", "GuideAbstract",ExpressionUUID->"4e442ab1-067c-4aa8-a49c-44248abcb635"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "GuideFunctionsSection",ExpressionUUID->"88bdc5d2-d829-429c-8f8d-bccc288a5754"],

Cell[CellGroupData[{

Cell["Chain projections", "GuideFunctionsSubsection",ExpressionUUID->"125a7496-07a0-49e7-9684-38c97e74a92d"],

Cell[TextData[{
 Cell[BoxData["ChainProjection"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "28608f5f-d406-443c-8200-e9b3b4557d55"],
 " \[LongDash] fraction of source events whose forward reach lands in the \
target chain"
}], "GuideText",ExpressionUUID->"1b9e3bf3-1369-4653-bd3b-1a1704bdd95d"],

Cell[TextData[{
 Cell[BoxData["ChainLightReach"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "1ae16c83-216e-463d-b78a-4838220fbe08"],
 " \[LongDash] joint future light front of a chain"
}], "GuideText",ExpressionUUID->"93c25867-8a2d-4192-9976-20c84c9c7f63"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Knuth scalars", "GuideFunctionsSubsection",ExpressionUUID->"82d2b6b6-f56d-484f-b869-6f0970ac6203"],

Cell[TextData[{
 Cell[BoxData["InfraEnergy"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "579053ab-aa2c-4886-b67b-fb337b4bf74f"],
 " \[LongDash] E = (p + q)/2 from two light-cone projections"
}], "GuideText",ExpressionUUID->"10ca93f3-601a-4591-88eb-a073d001ca07"],

Cell[TextData[{
 Cell[BoxData["InfraMomentum"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "6c70b3e4-ec5d-40a5-b93c-532180486378"],
 " \[LongDash] P = (p - q)/2"
}], "GuideText",ExpressionUUID->"bc5b916b-0667-4991-a659-1812646b72ea"],

Cell[TextData[{
 Cell[BoxData["InfraMass"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "0391d01f-f952-46bd-83d0-e397bb6d2134"],
 " \[LongDash] m = Sqrt[|p q|]"
}], "GuideText",ExpressionUUID->"b28a500f-faa8-4232-9b0e-046ad1148d8a"],

Cell[TextData[{
 Cell[BoxData["InfraInterval"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "3632d84d-c87b-4f29-89bb-f7a7527950bf"],
 " \[LongDash] squared interval p q = E^2 - P^2"
}], "GuideText",ExpressionUUID->"11ad66f4-b950-49d6-a66f-bccefac46a29"],

Cell[TextData[{
 Cell[BoxData["InfraVelocity"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "274b0c48-08df-4ece-946b-12d81bdefa20"],
 " \[LongDash] beta = (p - q)/(p + q)"
}], "GuideText",ExpressionUUID->"0432bbd3-50f1-4723-a856-89d80d496d52"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Pipeline", "GuideFunctionsSubsection",ExpressionUUID->"47ecdca0-f2d7-45dd-bb11-1708148ec547"],

Cell[TextData[{
 Cell[BoxData["InfraKinematics"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "7c20da3a-ba23-4d12-8c3c-cae6d4e11bab"],
 " \[LongDash] tabulates all Knuth scalars for a reference chain against \
target chains"
}], "GuideText",ExpressionUUID->"8c8c470e-98d9-4214-9368-8a5d9db99175"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Related Guides", "GuideMoreAboutSection",ExpressionUUID->"91ed7c1b-0f6f-4b3e-82aa-cfe0bb0adc79"],

