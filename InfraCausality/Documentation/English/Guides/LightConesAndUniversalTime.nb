Notebook[{

Cell[CellGroupData[{
Cell["Light Cones and Universal Time", "GuideTitle",ExpressionUUID->"4b833716-8e6a-4947-8271-6d64c6b541f9"],

Cell["\<\
Discrete light cones J+ and J-, causal intervals, the universal foliation by \
longest chain length from the sources, extremal events per slice, and \
combinatorial null geodesics.\
\>", "GuideAbstract",ExpressionUUID->"699c34c8-604e-489c-9df0-8d1a848462d9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["", "GuideFunctionsSection",ExpressionUUID->"24154582-d875-4a97-9c69-518601d55c42"],

Cell[CellGroupData[{

Cell["Light cones and causal intervals", "GuideFunctionsSubsection",ExpressionUUID->"2fe443a8-2836-4598-aec4-bd6fbc516c80"],

Cell[TextData[{
 Cell[BoxData["ForwardLightCone"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "16da8632-930b-4c4a-a535-338d65745de7"],
 " \[LongDash] subgraph of events reachable from v, the discrete J+(v)"
}], "GuideText",ExpressionUUID->"474b636a-55cd-45fc-89aa-bdf22c5bd304"],

Cell[TextData[{
 Cell[BoxData["BackwardLightCone"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "fe055248-614f-4901-9cc7-4ec1df48a856"],
 " \[LongDash] subgraph of events that reach v, the discrete J-(v)"
}], "GuideText",ExpressionUUID->"b66a7ff6-99aa-4a88-bade-42b66cfd53f7"],

Cell[TextData[{
 Cell[BoxData["CausalInterval"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "422f8ca8-199e-4408-9315-e8a77431b5b3"],
 " \[LongDash] subgraph of events between v1 and v2 in the causal order"
}], "GuideText",ExpressionUUID->"a9431a3f-971e-4864-b929-645855248c0b"],

Cell[TextData[{
 Cell[BoxData["ChainCausalInterval"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "f665c6b5-aa4c-4df7-945a-45d39b253cbb"],
 " \[LongDash] causal closure of a chain: events both reachable from and \
reaching the chain"
}], "GuideText",ExpressionUUID->"809867be-1205-4cc4-829a-1a6002cc3502"],

Cell[TextData[{
 Cell[BoxData["OutgoingLightRays"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "22b14b0c-4d72-412f-9b05-8f6e76f5ccd3"],
 " \[LongDash] events on outgoing null geodesics from v: no overtaking within \
the forward cone"
}], "GuideText",ExpressionUUID->"42e78e86-5335-4e10-9135-c53a5ef7dab2"],

Cell[TextData[{
 Cell[BoxData["IncomingLightRays"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "76a525f8-42b3-49ee-8081-6527b177e7f1"],
 " \[LongDash] events on incoming null geodesics into v, the time reverse"
}], "GuideText",ExpressionUUID->"46448ee1-f69b-4a9b-b9ff-61705fd1f1a5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Universal time and extremal events", "GuideFunctionsSubsection",ExpressionUUID->"2bef2ac1-e20a-4f8a-93e5-832b4cc304c8"],

Cell[TextData[{
 Cell[BoxData["UniversalFoliation"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "25d72c88-da97-4ce4-943f-6296b01c25af"],
 " \[LongDash] partition of events by longest chain length from the sources, \
the simultaneity slices"
}], "GuideText",ExpressionUUID->"4975f532-4fc2-4408-a41d-7056015367f9"],

Cell[TextData[{
 Cell[BoxData["UniversalTime"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "b9a392da-7efd-4970-969e-5d9506bde689"],
 " \[LongDash] slice index of every event as an Association"
}], "GuideText",ExpressionUUID->"b37bd872-9ff1-4f87-b7fc-c655f92c9df2"],

Cell[TextData[{
 Cell[BoxData["MaximalAbsorber"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "99603c9c-72c8-479b-8518-30a300e58e33"],
 " \[LongDash] per slice, the events with the largest causal past"
}], "GuideText",ExpressionUUID->"cc12bfd0-573e-474b-9034-cfebab5aae6c"],

Cell[TextData[{
 Cell[BoxData["MaximalEmitter"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "a21e813c-ec55-418f-94e7-e4b9db41450d"],
 " \[LongDash] per slice, the events with the largest causal future"
}], "GuideText",ExpressionUUID->"05b55512-e55c-40dc-aedc-72ecce4efd50"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Visualization", "GuideFunctionsSubsection",ExpressionUUID->"2be4923b-5753-4fee-89fa-f512da1b758a"],

Cell[TextData[{
