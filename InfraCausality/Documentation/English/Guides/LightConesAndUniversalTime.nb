rays"
}], "GuideText",ExpressionUUID->"8cd6bb48-eb4c-4d9b-80cb-ed28b5da691d"],

Cell[TextData[{
 Cell[BoxData["VisualizeFoliatedCausalGraph"], "InlineGuideFunction",
  TaggingRules->{"PageType" -> "Function"},ExpressionUUID->
  "e04c4419-4c47-4d00-8823-35e5df7e480c"],
